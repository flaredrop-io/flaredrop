{
  "name": "flaredrop",
  "version": "1.0.0",
  "description": "Self-hostable AirDrop alternative on Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute flaredrop-db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute flaredrop-db --remote --file=./schema.sql",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20240512.0",
    "@types/jsdom": "^28.0.1",
    "jsdom": "^29.0.1",
    "typescript": "^5.4.5",
    "vitest": "^2.1.0",
    "wrangler": "^3.57.0"
  }
}
